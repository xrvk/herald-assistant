# Scout Report — cp .env.example .env and fill in your values.
# See SETUP.md for detailed setup instructions.

# ── Calendars (at least one required) ── see SETUP.md §1
# Labels appear in LLM context and control work/personal classification.
# ICLOUD_URL=webcal://p60-caldav.icloud.com/published/2/YOUR_ID
# ICLOUD_LABEL=Personal
# OUTLOOK_URL=https://outlook.office365.com/owa/calendar/YOUR_ID/calendar.ics
# OUTLOOK_LABEL=Work
# GOOGLE_URL=https://calendar.google.com/calendar/ical/YOUR_ID/basic.ics
# GOOGLE_LABEL=Google
# Extra ICS feeds (CALENDAR_1 through CALENDAR_9):
# CALENDAR_1_URL=https://example.com/feed.ics
# CALENDAR_1_LABEL=Family

# ── Discord Bot (optional — omit for notification-only mode) ── see SETUP.md §2
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
# Restrict to specific users (comma-separated IDs, omit to allow all):
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432

# ── Notifications (required for scheduled digests) ── see SETUP.md §3
# Apprise URL — supports Discord webhooks, Telegram, 90+ services.
# https://github.com/caronc/apprise/wiki
# APPRISE_URL=discord://webhook_id/webhook_token

# Signal notifications via signal-cli REST API (optional, can be used instead of or alongside APPRISE_URL)
# Requires a running signal-cli REST API instance — see SETUP.md §3 and docker-compose.yaml.
# SIGNAL_CLI_REST_API_URL=http://signal-cli-rest-api:8080
# SIGNAL_FROM_NUMBER=+15555551234
# SIGNAL_TO_NUMBER=+16665554321
# To notify a group instead of a person, set SIGNAL_TO_NUMBER to the group ID:
# SIGNAL_TO_NUMBER=group.AbCdEfGhIjKlMnOp=

# ── LLM Backend ── see SETUP.md §4
# "gemini" (cloud, recommended — free tier, no GPU) or "ollama" (local, private)
LLM_BACKEND=gemini

# Gemini — get a free key: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_api_key_here
# GEMINI_MODEL=gemini-2.5-flash

# Ollama (optional — local inference, requires Ollama running on the host)
# LLM_BACKEND=ollama
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=gemma4:e4b

# ── Optional (sensible defaults) ──

# TZ=America/Los_Angeles

# Scheduled digests: "days HH:MM" or "off" (days: mon,tue,wed,thu,fri,sat,sun)
# WEEKNIGHT_SCHEDULE=sun,mon,tue,wed,thu 20:00
# WEEKEND_SCHEDULE=thu 16:00

# Calendar labels that count as "work" — controls digest filtering + LLM context
# WORK_LABELS=Work

# Hide events from digests and LLM (comma-separated substrings, case-insensitive)
# IGNORED_EVENTS=pick up kids,drop off kids,lunch

# CONTEXT_DAYS=7              # days of future events the LLM can see
# HISTORY_DAYS=10             # days of past events for history questions (0=off)
# HISTORY_CACHE_TTL=21600     # past-event cache in seconds (6h)
# CACHE_TTL=3600              # calendar fetch cache in seconds (1h)

# Conversation memory — enables follow-up questions
# CONV_HISTORY_TURNS=3        # Q+A pairs kept per user
# CONV_HISTORY_TTL=1800       # staleness timeout in seconds (30min)
# CONV_HISTORY_CTX_BUMP=4096  # extra Ollama context tokens (no effect on Gemini)

# Override the LLM personality (calendar data is appended automatically)
# SYSTEM_PROMPT=You are Friday, a sarcastic but helpful calendar assistant.
