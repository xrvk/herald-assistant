# Scout Report — cp .env.example .env, paste 3 values, deploy.
# Full guide: SETUP.md

# ── Required (paste your values) ──
CALENDAR_1_URL=
DISCORD_BOT_TOKEN=
GEMINI_API_KEY=

# ── More calendars ──
# CALENDAR_1_LABEL=Personal        # defaults to "Calendar 1" if omitted
# CALENDAR_2_URL=
# CALENDAR_2_LABEL=Work
# CALENDAR_3_URL=
# CALENDAR_3_LABEL=Family

# ── Scheduled digests ── uncomment these 4 lines to enable
# Weeknight = tomorrow's work meetings, Sun–Thu 20:00 (nights before workdays)
# Weekend   = Fri–Sun preview, Thu 16:00 (after work Thursday)
# APPRISE_URL=discord://webhook_id/webhook_token
# WORK_LABELS=Work
# WEEKNIGHT_SCHEDULE=sun,mon,tue,wed,thu 20:00
# WEEKEND_SCHEDULE=thu 16:00
# Webhook format: https://discord.com/api/webhooks/ID/TOKEN → discord://ID/TOKEN
# Schedule format: "days HH:MM", just "HH:MM" (keeps default days), or just days

# ── LLM options ──
LLM_BACKEND=gemini
# GEMINI_MODEL=gemini-2.5-flash-lite
# LLM_BACKEND=ollama                # switch to local inference; if GEMINI_API_KEY is also set,
#                                   # the bot silently falls back to Gemini when Ollama is unreachable
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=gemma4:e4b

# ── Everything below has sensible defaults ──
# TZ=America/Los_Angeles
# DISCORD_CHANNEL_ID=
# DISCORD_ALLOWED_USERS=123456789012345678,987654321098765432
# DISCORD_GUILD_ID=              # set to your server/guild ID for instant slash-command sync (local dev)
#                                #   Right-click server icon → Copy Server ID (requires Developer Mode)
#                                #   Omit (or leave blank) for global sync — changes propagate in ~1hr
# FILTERS_PATH=/app/data/filters.json  # where ignore/infoevent filters are persisted (Docker: mount a volume on /app/data)
# CONTEXT_DAYS=7              # future events the LLM can see
# HISTORY_DAYS=10             # past events for history questions (0=off)
# HISTORY_CACHE_TTL=21600     # past-event cache in seconds (6h)
# CACHE_TTL=3600              # calendar fetch cache in seconds (1h)
# MAX_OUTPUT_TOKENS=512       # max LLM response tokens
# CONV_HISTORY_TURNS=3        # Q+A pairs kept per user
# CONV_HISTORY_TTL=1800       # staleness timeout in seconds (30min)
# CONV_HISTORY_CTX_BUMP=4096  # extra Ollama context tokens (no effect on Gemini)
# SYSTEM_PROMPT=You are Kalinda, a sarcastic but helpful calendar assistant.
