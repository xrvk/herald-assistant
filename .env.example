# Calendars (at least one required)
CALENDAR_1_URL=webcal://your-ical-url.ics
CALENDAR_1_LABEL=Personal
# CALENDAR_2_URL=https://outlook.office365.com/owa/calendar/.../calendar.ics
# CALENDAR_2_LABEL=Work

# Timezone
TZ=America/Los_Angeles

# Notifications (required)
APPRISE_URL=discord://webhook_id/webhook_token

# Schedules (at least one must be enabled)
WEEKNIGHT_SCHEDULE=sun,mon,tue,wed,thu 18:00
WEEKEND_SCHEDULE=thu 15:00

# Work calendar filter
WORK_LABELS=Work

# Discord Bot (optional — enables online presence + commands)
# DISCORD_TOKEN=your-bot-token-here
